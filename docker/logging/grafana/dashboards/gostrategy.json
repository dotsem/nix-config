{
  "title": "Gostrategy — Operations",
  "uid": "gostrategy-ops",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "tags": [
    "gostrategy",
    "production"
  ],
  "panels": [
    {
      "type": "row",
      "title": "Player & User Insights",
      "id": 100,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Total Registered Users",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "gostrategy-prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gostrategy-prometheus"
          },
          "editorMode": "code",
          "expr": "gostrategy_users_total",
          "format": "time_series",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ]
    },
