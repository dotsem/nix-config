      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "gostrategy-prometheus"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Wins",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gostrategy-prometheus"
          },
          "editorMode": "code",
          "expr": "gostrategy_user_wins",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gostrategy-prometheus"
          },
          "editorMode": "code",
          "expr": "gostrategy_user_losses",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gostrategy-prometheus"
          },
          "editorMode": "code",
          "expr": "gostrategy_user_draws",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gostrategy-prometheus"
          },
          "editorMode": "code",
          "expr": "gostrategy_user_games",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gostrategy-prometheus"
          },
          "editorMode": "code",
          "expr": "gostrategy_user_avg_duration_minutes",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "E"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "username",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true
            },
            "indexByName": {
              "username": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5
            },
            "renameByName": {
              "username": "Player",
              "Value #A": "Wins",
              "Value #B": "Losses",
              "Value #C": "Draws",
              "Value #D": "Games",
              "Value #E": "Avg Min/Game"
            }
          }
        }
      ]
    },
