      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "unit": "short"
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "orange",
              "value": 1
            },
            {
              "color": "red",
              "value": 10
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"gostrategy-backend\"} |= \"[SECURITY]\" [5m]))",
          "legendFormat": "Security events",
          "refId": "A"
        }
      ]
    },
